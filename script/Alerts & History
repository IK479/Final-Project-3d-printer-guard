<script>
        // Micro-interaction for Threshold Slider
        const slider = document.getElementById('threshold-slider');
        const sliderVal = document.getElementById('threshold-val');
        
        slider.addEventListener('input', (e) => {
            sliderVal.textContent = `${e.target.value}%`;
            // Dynamic color shift logic mentioned in Brand Anchors
            if(e.target.value < 50) {
                sliderVal.className = 'font-mono-label text-headline-sm text-error';
            } else if(e.target.value < 80) {
                sliderVal.className = 'font-mono-label text-headline-sm text-secondary';
            } else {
                sliderVal.className = 'font-mono-label text-headline-sm text-primary';
            }
        });

        // Save Interaction
        const saveBtn = document.querySelector('button:contains("SAVE CONFIGURATION")') || document.querySelector('.bg-primary');
        const toast = document.getElementById('save-toast');

        saveBtn.addEventListener('click', () => {
            toast.classList.remove('translate-y-24', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');
            
            setTimeout(() => {
                toast.classList.add('translate-y-24', 'opacity-0');
                toast.classList.remove('translate-y-0', 'opacity-100');
            }, 3000);
        });

        // Hover atmosphere effect for sections
        const sections = document.querySelectorAll('section');
        sections.forEach(section => {
            section.addEventListener('mouseenter', () => {
                section.querySelector('.bg-surface-container').classList.add('border-primary/50');
            });
            section.addEventListener('mouseleave', () => {
                section.querySelector('.bg-surface-container').classList.remove('border-primary/50');
            });
        });
    </script>
